# ============================================================
# ColorVerse Git Ignore Rules
# ============================================================

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Production builds
dist/
frontend/dist/

# Environment files (secrets - keep gitignored)
.env
backend/.env
frontend/.env
# NOTE: frontend/.env.production is intentionally tracked (only public URLs)

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.logs/

# System files
.DS_Store
Thumbs.db
